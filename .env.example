
# Скопируйте этот файл в .env и заполните своими значениями

# ─── ФРОНТЕНД ────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000/api/v1

# ─── БЭКЕНД ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ─── БАЗА ДАННЫХ ─────────────────────────────────────────────────────────────
# Вариант 1: Supabase (облако, бесплатно)
#   1. Зайдите на supabase.com → New Project
#   2. Настройки → Database → Connection string → Transaction
#   3. Скопируйте строку вида: postgresql://postgres.xxx:PASSWORD@aws-1-eu-north-1.pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://postgres.XXXX:YOUR_PASSWORD@aws-1-eu-north-1.pooler.supabase.com:6543/postgres"

# Вариант 2: Локальный PostgreSQL
# DATABASE_URL="postgresql://postgres:password@localhost:5432/lsauto"

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Секретный ключ (минимум 64 символа!)
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-min-64-chars-change-this-in-production"

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Разрешённые домены (через запятую) или * только для разработки
ALLOWED_ORIGIN=https://yourdomain.com

# ─── EMAIL (опционально) ──────────────────────────────────────────────────────
# Оставьте пустым для отключения email-уведомлений
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password_from_google
# SMTP_FROM="LSAUTO <noreply@yourdomain.com>"

# ─── ДОПОЛНИТЕЛЬНО ────────────────────────────────────────────────────────────
# Уровень логирования: fatal, error, warn, info, debug, trace
# LOG_LEVEL=debug
